---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />

  {/* 히어로 섹션 */}
  <section id="hero">
    <div class="app-layout border-b border-border py-10 sm:py-14">
      <p class="text-sm font-medium tracking-widest text-accent uppercase">
        Blog
      </p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
        나의 개발 아카이브
      </h1>
      <p class="mt-3 max-w-md text-base leading-relaxed text-foreground/50">
        개발하며 마주친 것들
      </p>
      <div class="mt-5 flex items-center gap-3">
        {SOCIALS.length > 0 && <Socials />}
        <a
          target="_blank"
          href="/rss.xml"
          class="text-foreground/30 transition-colors hover:text-accent"
          aria-label="RSS 피드"
          title="RSS 피드"
        >
          <IconRss width={16} height={16} class="stroke-current stroke-2" />
        </a>
      </div>
    </div>
  </section>

  <main id="main-content" data-layout="index" class="app-layout">

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">추천 게시글</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">최근 게시글</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        모든 게시글
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
